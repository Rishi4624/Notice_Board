datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Notice {
  id          String   @id @default(uuid())
  title       String
  body        String
  category    Category
  priority    Priority
  publishDate DateTime
  image       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Category {
  Exam
  Event
  General
}

enum Priority {
  Normal
  Urgent
}
